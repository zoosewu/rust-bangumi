{
  "openapi": "3.0.3",
  "info": {
    "title": "Bangumi Core API",
    "description": "Core service API for Rust Bangumi — anime content management system",
    "contact": {
      "name": "Claude Code"
    },
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/core/anime": {
      "get": {
        "tags": [
          "Anime"
        ],
        "summary": "List all anime with enriched data (work_title, season, episode counts, subscriptions)",
        "operationId": "list_all_anime",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AnimeRichResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "post": {
        "tags": [
          "Anime"
        ],
        "summary": "Create a new anime (formerly anime series)",
        "operationId": "create_anime",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/anime-works": {
      "get": {
        "tags": [
          "AnimeWorks"
        ],
        "summary": "List all anime works",
        "operationId": "list_anime_work",
        "parameters": [
          {
            "name": "has_links",
            "in": "query",
            "description": "Filter to anime works that have at least one link",
            "required": false,
            "schema": {
              "type": "boolean",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeWorksListResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "post": {
        "tags": [
          "AnimeWorks"
        ],
        "summary": "Create a new anime work",
        "operationId": "create_anime_work",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimeWorkRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeWorkResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/anime-works/{work_id}": {
      "get": {
        "tags": [
          "AnimeWorks"
        ],
        "summary": "Get anime work by ID",
        "operationId": "get_anime_work",
        "parameters": [
          {
            "name": "work_id",
            "in": "path",
            "description": "Anime work ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeWorkResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "delete": {
        "tags": [
          "AnimeWorks"
        ],
        "summary": "Delete anime work by ID",
        "operationId": "delete_anime_work",
        "parameters": [
          {
            "name": "work_id",
            "in": "path",
            "description": "Anime work ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted successfully"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/anime-works/{work_id}/anime": {
      "get": {
        "tags": [
          "Anime"
        ],
        "summary": "List anime by work_id",
        "description": "List anime by work_id (formerly list_anime_series by anime_id)",
        "operationId": "list_anime",
        "parameters": [
          {
            "name": "work_id",
            "in": "path",
            "description": "Anime work ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/anime/{anime_id}": {
      "get": {
        "tags": [
          "Anime"
        ],
        "summary": "Get anime by ID",
        "description": "Get anime by ID (formerly anime series)",
        "operationId": "get_anime",
        "parameters": [
          {
            "name": "anime_id",
            "in": "path",
            "description": "Anime series ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "put": {
        "tags": [
          "Anime"
        ],
        "summary": "Update anime by ID (partial update: description, aired_date, end_date)",
        "operationId": "update_anime",
        "parameters": [
          {
            "name": "anime_id",
            "in": "path",
            "description": "Anime series ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAnimeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/dashboard/stats": {
      "get": {
        "tags": [
          "Dashboard"
        ],
        "summary": "Get dashboard statistics",
        "operationId": "get_dashboard_stats",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardStats"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/downloads": {
      "get": {
        "tags": [
          "Downloads"
        ],
        "summary": "List download records",
        "operationId": "list_downloads",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by download status (pending, downloading, completed, failed)",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of records to return",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "nullable": true
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of records to skip",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/filters": {
      "get": {
        "tags": [
          "Filters"
        ],
        "summary": "Get filter rules. When target_type is omitted, returns all rules sorted global-first.",
        "operationId": "get_filter_rules",
        "parameters": [
          {
            "name": "target_type",
            "in": "query",
            "description": "Filter by target type (global, anime, group)",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "target_id",
            "in": "query",
            "description": "Filter by target ID",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FilterRuleResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "post": {
        "tags": [
          "Filters"
        ],
        "summary": "Create a new filter rule",
        "operationId": "create_filter_rule",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FilterRuleRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilterRuleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid target type or regex pattern"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/filters/{rule_id}": {
      "delete": {
        "tags": [
          "Filters"
        ],
        "summary": "Delete a filter rule by rule_id",
        "operationId": "delete_filter_rule",
        "parameters": [
          {
            "name": "rule_id",
            "in": "path",
            "description": "Filter rule ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted successfully"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/links": {
      "post": {
        "tags": [
          "Links"
        ],
        "summary": "Create a new anime link",
        "operationId": "create_anime_link",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimeLinkRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeLinkResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/links/conflicts": {
      "get": {
        "tags": [
          "Links"
        ],
        "summary": "List all anime links with conflict_flag = true, enriched with series/anime/subscription info",
        "operationId": "list_conflicting_links",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ConflictingLinkResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/links/{series_id}": {
      "get": {
        "tags": [
          "Links"
        ],
        "summary": "Get anime links by series_id — returns ALL links (filtered + unfiltered) with group_name and download status",
        "operationId": "get_anime_links",
        "parameters": [
          {
            "name": "series_id",
            "in": "path",
            "description": "Anime series ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AnimeLinkRichResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/seasons": {
      "get": {
        "tags": [
          "Seasons"
        ],
        "summary": "List all seasons",
        "operationId": "list_seasons",
        "responses": {
          "200": {
            "description": "Success"
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "post": {
        "tags": [
          "Seasons"
        ],
        "summary": "Create a new season",
        "operationId": "create_season",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SeasonRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created or found existing season",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeasonResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/subtitle-groups": {
      "get": {
        "tags": [
          "SubtitleGroups"
        ],
        "summary": "List all subtitle groups",
        "operationId": "list_subtitle_groups",
        "responses": {
          "200": {
            "description": "Success"
          },
          "500": {
            "description": "Database error"
          }
        }
      },
      "post": {
        "tags": [
          "SubtitleGroups"
        ],
        "summary": "Create a new subtitle group",
        "operationId": "create_subtitle_group",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubtitleGroupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubtitleGroupResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    },
    "/api/core/subtitle-groups/{group_id}": {
      "delete": {
        "tags": [
          "SubtitleGroups"
        ],
        "summary": "Delete subtitle group by ID",
        "operationId": "delete_subtitle_group",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "description": "Subtitle group ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted successfully"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Database error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnimeLinkConflictInfo": {
        "type": "object",
        "required": [
          "conflict_id",
          "series_id",
          "group_id",
          "episode_no",
          "anime_title",
          "group_name",
          "resolution_status",
          "links",
          "created_at"
        ],
        "properties": {
          "anime_title": {
            "type": "string"
          },
          "chosen_link_id": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "conflict_id": {
            "type": "integer",
            "format": "int32"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "episode_no": {
            "type": "integer",
            "format": "int32"
          },
          "group_id": {
            "type": "integer",
            "format": "int32"
          },
          "group_name": {
            "type": "string"
          },
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnimeLinkConflictLink"
            }
          },
          "resolution_status": {
            "type": "string"
          },
          "series_id": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "AnimeLinkConflictLink": {
        "type": "object",
        "required": [
          "link_id",
          "url",
          "source_hash",
          "conflict_flag",
          "link_status",
          "created_at",
          "sibling_episodes"
        ],
        "properties": {
          "conflict_flag": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "download": {
            "allOf": [
              {
                "$ref": "#/components/schemas/DownloadInfo"
              }
            ],
            "nullable": true
          },
          "link_id": {
            "type": "integer",
            "format": "int32"
          },
          "link_status": {
            "type": "string"
          },
          "raw_item_id": {
            "type": "integer",
            "format": "int32",
            "description": "此 link 來源的 raw_item_id（若有）",
            "nullable": true
          },
          "raw_item_title": {
            "type": "string",
            "description": "此 link 來源 raw_item 的標題（若有）",
            "nullable": true
          },
          "sibling_episodes": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "description": "同一 raw_item 下其他 episode_no（不含當前 conflict 的 episode），\n用於前端提示「此來源同時涵蓋哪些其他集數」（batch raw_item 才會非空）"
          },
          "source_hash": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string"
          }
        }
      },
      "AnimeLinkRequest": {
        "type": "object",
        "required": [
          "series_id",
          "group_id",
          "episode_no",
          "url",
          "source_hash"
        ],
        "properties": {
          "episode_no": {
            "type": "integer",
            "format": "int32"
          },
          "group_id": {
            "type": "integer",
            "format": "int32"
          },
          "series_id": {
            "type": "integer",
            "format": "int32"
          },
          "source_hash": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string"
          }
        }
      },
      "AnimeLinkResponse": {
        "type": "object",
        "required": [
          "link_id",
          "series_id",
          "group_id",
          "episode_no",
          "url",
          "source_hash",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "episode_no": {
            "type": "integer",
            "format": "int32"
          },
          "group_id": {
            "type": "integer",
            "format": "int32"
          },
          "link_id": {
            "type": "integer",
            "format": "int32"
          },
          "series_id": {
            "type": "integer",
            "format": "int32"
          },
          "source_hash": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string"
          }
        }
      },
      "AnimeLinkRichResponse": {
        "type": "object",
        "required": [
          "link_id",
          "series_id",
          "group_id",
          "group_name",
          "episode_no",
          "url",
          "source_hash",
          "filtered_flag",
          "conflict_flag",
          "conflicting_link_ids",
          "created_at"
        ],
        "properties": {
          "conflict_flag": {
            "type": "boolean"
          },
          "conflicting_link_ids": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "download": {
            "allOf": [
              {
                "$ref": "#/components/schemas/DownloadInfo"
              }
            ],
            "nullable": true
          },
          "episode_no": {
            "type": "integer",
            "format": "int32"
          },
          "filtered_flag": {
            "type": "boolean"
          },
          "group_id": {
            "type": "integer",
            "format": "int32"
          },
          "group_name": {
            "type": "string"
          },
          "link_id": {
            "type": "integer",
            "format": "int32"
          },
          "series_id": {
            "type": "integer",
            "format": "int32"
          },
          "source_hash": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string"
          }
        }
      },
      "AnimeRequest": {
        "type": "object",
        "required": [
          "anime_id",
          "series_no",
          "season_id"
        ],
        "properties": {
          "aired_date": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "anime_id": {
            "type": "integer",
            "format": "int32"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "season_id": {
            "type": "integer",
            "format": "int32"
          },
          "series_no": {
            "type": "integer",
            "format": "int32"
          }
